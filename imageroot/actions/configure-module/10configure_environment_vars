import json
import sys
import agent

# Try to parse the stdin as JSON.
# If parsing fails, output everything to stderr
data = json.load(sys.stdin)

if data.get("password","") == "":
  exit(0)

username = data.get("username","")
password = data.get("password","")

# Setup default values
host = data.get("host")
h2hs = data.get("http2https", True)

agent.set_env("TRAEFIK_HOST", host)
agent.set_env("TRAEFIK_HTTP2HTTPS", h2hs)

config = {
  "DEFAULT_ADMIN_USERNAME": username,
  "DEFAULT_ADMIN_PASSWORD": password
}
agent.write_envfile('config.env', config)

# For later use and backup
with open('config.json', 'w') as cfp:
  cfp.write(json.dumps(data))